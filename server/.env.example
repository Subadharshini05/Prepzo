# Backend Example Environment Variables
# Copy this file to .env and update with your actual values

NODE_ENV=development
PORT=5000

# Database Configuration
# For local development:
DATABASE_URL="mysql://prepzo_user:prepzo_password@localhost:3306/prepzo_dev"
# For Docker:
# DATABASE_URL="mysql://prepzo_user:prepzo_password@db:3306/prepzo_dev"

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRE=30d

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./src/uploads

# CORS Configuration
CLIENT_URL=http://localhost:5173

# Email Configuration (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cloud Storage (Optional - for future use)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=prepzo-uploads

# Logging
LOG_LEVEL=debug
